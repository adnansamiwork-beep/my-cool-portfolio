{
  "entities": {
    "Portfolio": {
      "title": "Portfolio",
      "description": "Portfolio data including profile, projects, and gallery",
      "type": "object",
      "properties": {
        "profile": { "type": "object", "description": "Profile details" },
        "projects": { "type": "array", "description": "List of projects" },
        "gallery": { "type": "array", "description": "Gallery memories" }
      },
      "required": ["profile", "projects", "gallery"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Website visitor metrics",
      "type": "object",
      "properties": {
        "views": { "type": "number" },
        "loadingSpeed": { "type": "number" },
        "visitorCountries": { "type": "array" },
        "viewsByDay": { "type": "array" }
      },
      "required": ["views"]
    }
  },
  "firestore": {
    "portfolio/sami": {
      "schema": "Portfolio",
      "description": "Adnan Sami custom portfolio dataset"
    },
    "analytics/sami": {
      "schema": "Analytics",
      "description": "Page tracking and analytics views metrics"
    }
  }
}
